module Stalling_Unit #(
    parameter ADDRESS_BUS_WIDTH = 5,
    parameter DATA_BUS_WIDTH    = 32
) (
    input [1:0]                     PCSrc, ResultSrcE,
    input [ADDRESS_BUS_WIDTH-1 : 0] A1D, A2D, RdE,
    output reg                      StallF, StallD, FlushD, FlushE
);

    always @(*) begin
        
        FlushD = PCSrc;

        if (ResultSrcE == 1 && ((RdE == A1D) || (RdE == A2D))) begin
            StallF, StallD = 0 ;
            FlushE = 1 ; // PCSRC | LWStall(1)
        end
        else begin
            StallF, StallD = 1 ;
            FlushE = PCSrc ; // PCSRC | LWStall(0)
        end
    end
    
endmodule